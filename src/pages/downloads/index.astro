---
import PageLayout from '../../layouts/PageLayout.astro';
import CheatSheetDownloads from '../../components/CheatSheetDownloads.astro';
import { allUnits, cheatSheets } from '../../data/curriculum';
import { cheatSheetHasDownloads } from '../../lib/downloads';
import { url } from '../../lib/paths';
---

<PageLayout
  title="Downloads"
  description="Download all Free Ham Radio Curriculum PDFs and handouts in one place."
  current="downloads"
>
  <h1>Downloads</h1>
  <p>All curriculum PDFs and cheat sheets in one place. Preview materials are available now; others follow as units are published.</p>

  <h2>Workshops and activities</h2>
  <ul class="unit-list">
    {
      allUnits.map((unit) => (
        <li>
          <a href={url(`/curriculum/${unit.track}/${unit.slug}/`)}>
            <div>
              <h3>{unit.title}</h3>
              <p>{unit.description}</p>
            </div>
            <span class="badge badge-coming">PDFs coming soon</span>
          </a>
        </li>
      ))
    }
  </ul>

  <h2>Cheat sheets</h2>
  <div>
    {
      cheatSheets.map((sheet) => (
        <div class="download-row">
          <div>
            <h3>
              <a href={url(`/reference/cheat-sheets/${sheet.slug}/`)}>{sheet.title}</a>
            </h3>
            <p>{sheet.description}</p>
          </div>
          {
            cheatSheetHasDownloads(sheet.slug) ? (
              <CheatSheetDownloads slug={sheet.slug} />
            ) : (
              <span class="badge badge-coming">Coming soon</span>
            )
          }
        </div>
      ))
    }
  </div>
</PageLayout>
