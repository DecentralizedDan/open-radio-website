---
import PageLayout from '../layouts/PageLayout.astro';
import { url } from '../lib/paths';
---

<PageLayout title="Page not found" description="The page you requested could not be found.">
  <h1>Page not found</h1>
  <p>
    That URL isn&apos;t on the air. The page may have moved, or the link may be mistyped.
  </p>
  <div class="hero-actions" style="margin-top: 1.5rem;">
    <a class="btn btn-primary" href={url('/')}>Home</a>
    <a class="btn btn-secondary" href={url('/curriculum/')}>Browse curriculum</a>
    <a class="btn btn-secondary" href={url('/start/for-trainers/')}>For trainers</a>
  </div>
</PageLayout>
