---
import PageLayout from '../../layouts/PageLayout.astro';
import UnitList from '../../components/UnitList.astro';
import {
  activities,
  allUnits,
  digitalTrack,
  licenseLabel,
  phoneTrack,
  unitPath,
} from '../../data/curriculum';
import { url } from '../../lib/paths';

const sortedAll = [...allUnits].sort((a, b) => a.title.localeCompare(b.title));
---

<PageLayout
  title="Curriculum"
  description="Browse workshops and activities — phone track, digital track, and standalone activities."
  current="curriculum"
>
  <h1>Curriculum</h1>
  <p>Ten workshops and five activities. Pick one unit or follow a track from intro to HF.</p>

  <nav class="hub-jumps" aria-label="Browse curriculum">
    <a href="#phone">Phone track</a>
    <a href="#digital">Digital track</a>
    <a href="#activities">Activities</a>
    <a href="#all">All A–Z</a>
  </nav>

  <section id="phone" class="unit-section">
    <h2>Phone track</h2>
    <p>Voice operating from emergency intro through HF. <a href={url('/curriculum/phone/')}>View track page →</a></p>
    <UnitList units={phoneTrack} />
  </section>

  <section id="digital" class="unit-section">
    <h2>Digital track</h2>
    <p>Mesh and digital modes through HF digital QSOs. <a href={url('/curriculum/digital/')}>View track page →</a></p>
    <UnitList units={digitalTrack} />
  </section>

  <section id="activities" class="unit-section">
    <h2>Activities</h2>
    <p>Standalone events — no required order. <a href={url('/curriculum/activities/')}>View activities →</a></p>
    <UnitList units={activities} />
  </section>

  <section id="all" class="unit-section">
    <h2>All units A–Z</h2>
    <ul class="unit-list">
      {
        sortedAll.map((unit) => (
          <li>
            <a href={unitPath(unit)}>
              <div>
                <h3>{unit.title}</h3>
                <p>{unit.description}</p>
              </div>
              <div class="unit-meta">
                <span class="badge">{unit.type}</span>
                <span class="badge">{licenseLabel(unit.license)}</span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>
