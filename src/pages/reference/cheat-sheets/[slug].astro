---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CheatSheetDownloads from '../../../components/CheatSheetDownloads.astro';
import RelatedUnits from '../../../components/RelatedUnits.astro';
import { cheatSheets } from '../../../data/curriculum';
import { url } from '../../../lib/paths';

export function getStaticPaths() {
  return cheatSheets.map((sheet) => ({
    params: { slug: sheet.slug },
    props: { sheet },
  }));
}

interface Props {
  sheet: (typeof cheatSheets)[number];
}

const { sheet } = Astro.props;
---

<PageLayout title={sheet.title} description={sheet.description} current="reference">
  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Cheat sheets', href: '/reference/cheat-sheets/' },
      { label: sheet.title },
    ]}
  />
  <h1>{sheet.title}</h1>
  <p>{sheet.description}</p>
  <p>
    {
      sheet.ready ? (
        <span class="badge badge-ready">Preview</span>
      ) : (
        <span class="badge badge-coming">PDF coming soon</span>
      )
    }
  </p>
  {
    sheet.ready ? (
      <>
        <p>Laminate-friendly — free to print and share.</p>
        <CheatSheetDownloads slug={sheet.slug} />
      </>
    ) : (
      <p>This reference card will be available to view online and download as a PDF when published.</p>
    )
  }
  <RelatedUnits sheet={sheet} />
  <p style="margin-top: 1.5rem;"><a href={url('/reference/cheat-sheets/')}>← All cheat sheets</a></p>
</PageLayout>
