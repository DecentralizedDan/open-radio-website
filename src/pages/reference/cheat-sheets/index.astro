---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CheatSheetDownloads from '../../../components/CheatSheetDownloads.astro';
import { cheatSheets } from '../../../data/curriculum';
import { cheatSheetHasDownloads } from '../../../lib/downloads';
import { url } from '../../../lib/paths';
---

<PageLayout
  title="Cheat sheets"
  description="Print-and-laminate reference cards for Free Ham Radio Curriculum workshops."
  current="reference"
>
  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Cheat sheets' },
    ]}
  />
  <h1>Cheat sheets</h1>
  <p>
    Full- or half-page references to get new operators on the air. Laminate-friendly — free to
    print and share.
  </p>

  <div class="cheat-grid" style="margin-top: 1.5rem;">
    {
      cheatSheets.map((sheet) => {
        const hasDownloads = cheatSheetHasDownloads(sheet.slug);
        return hasDownloads || sheet.ready ? (
          <div class="card card-static">
            <h3>
              <a class="card-title-link" href={url(`/reference/cheat-sheets/${sheet.slug}/`)}>{sheet.title}</a>
            </h3>
            <p>{sheet.description}</p>
            {sheet.ready && <span class="badge badge-ready" style="margin-top: 0.75rem;">Preview draft</span>}
            {hasDownloads ? (
              <CheatSheetDownloads slug={sheet.slug} />
            ) : (
              <span class="badge badge-coming" style="margin-top: 0.75rem;">Coming soon</span>
            )}
          </div>
        ) : (
          <a class="card" href={url(`/reference/cheat-sheets/${sheet.slug}/`)}>
            <h3>{sheet.title}</h3>
            <p>{sheet.description}</p>
            <span class="badge badge-coming" style="margin-top: 0.75rem;">Coming soon</span>
          </a>
        );
      })
    }
  </div>
</PageLayout>
