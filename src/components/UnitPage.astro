---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import RelatedCheatSheets from './RelatedCheatSheets.astro';
import {
  getAdjacentUnits,
  licenseLabel,
  trackLabel,
  type Unit,
} from '../data/curriculum';
import CopyButton from './CopyButton.astro';
import WorkshopMaterialDownloads from './WorkshopMaterialDownloads.astro';
import { workshopMaterialHasDownloads } from '../lib/downloads';
import { url } from '../lib/paths';

interface Props {
  unit: Unit;
}

const { unit } = Astro.props;
const { prev, next } = getAdjacentUnits(unit);
const trackHref = url(`/curriculum/${unit.track}/`);
---

<PageLayout title={unit.title} description={unit.description} current="curriculum">
  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Curriculum', href: '/curriculum/' },
      { label: trackLabel(unit.track), href: trackHref },
      { label: unit.title },
    ]}
  />

  <div class="unit-meta" style="margin-bottom: 1rem;">
    <span class="badge">{unit.type}</span>
    <span class="badge">{licenseLabel(unit.license)}</span>
    <span class="badge">{unit.duration}</span>
    {unit.ready ? (
      <span class="badge badge-ready">Preview draft</span>
    ) : (
      <span class="badge badge-coming">Coming soon</span>
    )}
  </div>

  <h1>{unit.title}</h1>
  <p>{unit.description}</p>

  <nav class="section-nav" aria-label="Page sections">
    <a href="#overview">Overview</a>
    <a href="#materials">Materials</a>
    <a href="#promo">Promo copy</a>
    <a href="#run">Run this workshop</a>
  </nav>

  <section id="overview" class="unit-section">
    <h2>Overview</h2>
    {
      unit.ready && unit.slug === 'emergency-radio-101' ? (
        <>
          <p>
            <strong>After this workshop, learners will:</strong>
          </p>
          <ul>
            <li>Understand how radio was used after disasters in the US</li>
            <li>Understand fundamentals of what GMRS and Ham radio can and cannot do</li>
            <li>Understand how GMRS and Ham differ, including Ham's strengths vs. GMRS</li>
          </ul>
          <p>
            <strong>Duration:</strong> {unit.duration} · <strong>Group size:</strong> 5-95 ·{' '}
            <strong>Setting:</strong> Indoor
          </p>
          <p>
            <strong>License:</strong> {licenseLabel(unit.license)} · <strong>Equipment:</strong>{' '}
            Projector, sample HT to show learners
          </p>
        </>
      ) : (
        <>
          <p>Full trainer overview and learner outcomes will appear here when this unit is published.</p>
          <p>
            <strong>Duration:</strong> {unit.duration} · <strong>License:</strong>{' '}
            {licenseLabel(unit.license)}
          </p>
        </>
      )
    }

    <RelatedCheatSheets unit={unit} />

    {
      next && (
        <p>
          <strong>What comes next:</strong>{' '}
          <a href={url(`/curriculum/${next.track}/${next.slug}/`)}>{next.title}</a>
        </p>
      )
    }
  </section>

  <section id="materials" class="unit-section">
    <h2>Materials</h2>
    {
      unit.ready ? (
        <div class="materials-grid">
          <div class="material-card">
            <h3>Slides</h3>
            <p>60–90 minute slide deck with speaker notes.</p>
            {
              workshopMaterialHasDownloads(unit.slug, 'slides') ? (
                <WorkshopMaterialDownloads slug={unit.slug} material="slides" />
              ) : (
                <span class="badge badge-coming">PDF coming soon</span>
              )
            }
          </div>
          <div class="material-card">
            <h3>Learner handout</h3>
            <p>Take-home reference — complements the slides.</p>
            {
              workshopMaterialHasDownloads(unit.slug, 'handout') ? (
                <WorkshopMaterialDownloads slug={unit.slug} material="handout" />
              ) : (
                <span class="badge badge-coming">PDF coming soon</span>
              )
            }
          </div>
          <div class="material-card">
            <h3>Trainer guide</h3>
            <p>For instructors — logistics, equipment, success criteria.</p>
            {
              workshopMaterialHasDownloads(unit.slug, 'trainer-guide') ? (
                <WorkshopMaterialDownloads slug={unit.slug} material="trainer-guide" />
              ) : (
                <span class="badge badge-coming">PDF coming soon</span>
              )
            }
          </div>
        </div>
      ) : (
        <p>Slides, handout, and trainer guide will be available here when this unit is published.</p>
      )
    }
  </section>

  <section id="promo" class="unit-section">
    <h2>Promo copy</h2>
    {
      unit.ready && unit.slug === 'emergency-radio-101' ? (
        <>
          <div class="promo-block">
            <div class="promo-block-header">
              <strong>Long (email / newsletter)</strong>
              <CopyButton targetId="promo-long" />
            </div>
            <pre id="promo-long">
Radio lets you communicate with your people without depending on cell towers, ISPs, or even running electricity -- but only if you know how it works! 

Come to this workshop to learn how to make radio part of your emergency preparedness plan. We'll cover three different types of radio technology, specific models that are good for beginners, how you can take advantage of existing radio infrastructure, how (and if!) to get licensed, and much more. We will cover Meshtastic and Meshcore.

No radio knowledge is needed or expected. Total beginners are welcome to this workshop. 90 minutes total, including Q&A at the end.
            </pre>
          </div>
          <div class="promo-block">
            <div class="promo-block-header">
              <strong>Medium</strong>
              <CopyButton targetId="promo-medium" />
            </div>
            <pre id="promo-medium">
Learn how radio can help you, your family, and your community during a disaster in this fun and engaging workshop! We'll cover three different radio technologies you can use — all in 90 minutes. No prior radio knowledge needed.
            </pre>
          </div>
          <div class="promo-block">
            <div class="promo-block-header">
              <strong>Short (SMS)</strong>
              <CopyButton targetId="promo-short" />
            </div>
            <pre id="promo-short">The Emergency Radio 101 workshop covers how radio can help you your people in a disaster in 90 minutes. No experience needed. See you there!</pre>
          </div>
        </>
      ) : (
        <p>Long, medium, and short promo blurbs will appear here when this unit is published.</p>
      )
    }
  </section>

  <section id="run" class="unit-section">
    <h2>Run this workshop</h2>
    {
      unit.ready && unit.slug === 'emergency-radio-101' ? (
        <>
          <p><strong>5-minute prep checklist</strong></p>
          <ul>
            <li>Skim trainer guide and slide notes</li>
            <li>Test projector and slides</li>
            <li>Print handouts (one per learner)</li>
            <li>Optional: bring an HT (FRS, GMRS or Ham) for show-and-tell</li>
          </ul>
          <p>
            <strong>Success criteria:</strong> Learners can explain how they could incorporate
            radio into their emergency planning.
          </p>
        </>
      ) : (
        <p>Prep checklist and success criteria will appear here when this unit is published.</p>
      )
    }
    <RelatedCheatSheets unit={unit} heading="Related cheat sheets" />
    {
      unit.cheatSheets && unit.cheatSheets.length > 0 && (
        <p>Print one per learner before class.</p>
      )
    }
    {
      unit.cheatSheets && unit.cheatSheets.length > 0 && (
        <p>
          <a href={url('/reference/cheat-sheets/')}>All cheat sheets →</a>
        </p>
      )
    }
  </section>

  {
    (prev || next) && (
      <nav class="unit-nav-footer" aria-label="Track navigation">
        {prev ? (
          <a href={url(`/curriculum/${prev.track}/${prev.slug}/`)}>← {prev.title}</a>
        ) : (
          <span />
        )}
        {next ? (
          <a href={url(`/curriculum/${next.track}/${next.slug}/`)}>{next.title} →</a>
        ) : (
          <span />
        )}
      </nav>
    )
  }
</PageLayout>
