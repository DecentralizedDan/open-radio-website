---
import { phoneTrack, digitalTrack, unitPath } from '../data/curriculum';
---

<div class="path-diagram" aria-label="Learning paths from beginner to HF">
  <h2>Two tracks to take learners from zero to HF</h2>
  <p class="path-goal">Learners can choose one path -- or do both.</p>
  <div class="path-columns">
    <div class="path-track">
      <h3>Phone track</h3>
      <ol class="path-steps">
        {phoneTrack.map((unit) => (
          <li>
            <a href={unitPath(unit)}>{unit.title}</a>
          </li>
        ))}
      </ol>
    </div>
    <div class="path-track">
      <h3>Digital track</h3>
      <ol class="path-steps">
        {digitalTrack.map((unit) => (
          <li>
            <a href={unitPath(unit)}>{unit.title}</a>
          </li>
        ))}
      </ol>
    </div>
  </div>
</div>
