---
import {
  workshopMaterialDownloads,
  type WorkshopMaterial,
} from '../lib/downloads';

interface Props {
  slug: string;
  material: WorkshopMaterial;
}

const { slug, material } = Astro.props;
const downloads = workshopMaterialDownloads(slug, material);
---

{
  downloads.length > 0 && (
    <div class="download-actions">
      {
        downloads.map(({ href, label, primary, title }) => (
          <a
            class={primary ? 'btn btn-primary' : 'btn btn-secondary'}
            href={href}
            download
            title={title}
          >
            {label}
          </a>
        ))
      }
    </div>
  )
}
